<section id="posts">
  <h1>Posts list</h1>
  <div class="posts-user">
    <div class="posts-user-photo-container">
      <img src="<%= @user.photo %>" alt="avatar" class="posts-user-photo">
    </div>
    <div class="posts-user-details">
      <h2>
        <%= @user.name %>
      </h2>
      <p>
        Number of posts: <%= @user.posts_counter %>
      </p>
    </div>
  </div>

  <div class="posts-container">
    <ul class="posts-list-container">
      <% @posts.each do |post| %>

        <li class="post-item">
          <%= link_to user_post_path(@user.id, post.id), class: "post-link" do %>
            <div class="post-text">
              <h2>
                <%= post.title %>
              </h2>
              <p>
                <%= post.text %>
              </p>
              <div class="comments-and-likes">
                <p>
                  Comments <%= post.comments_counter %>
                </p>
                <p>
                  likes <%= post.likes_counter %>
                </p>
              </div>
            </div>
          <% end %>

          <div class="comments-section">
            <% if post.recent_comments.length == 0 %>
              <p class="no-comments">This post has no comments yet</p>
            <% else %>
              <% post.recent_comments.each do |comment| %>
                <h3>
                  <%= comment.author %>
                  <%= comment.text %>
                </h3>
              <% end %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="pagination-btn-container">
      <button type="button" class="pagination-btn">Pagination</button>
    </div>
  </div>
</section>


